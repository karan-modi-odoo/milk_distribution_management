<odoo>

    <record id="action_report_payment_receipt" model="ir.actions.report">
        <field name="name">Payment Receipt</field>
        <field name="model">milk.cash.collection</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">milk_distribution_management.report_payment_receipt</field>
        <field name="binding_model_id" ref="model_milk_cash_collection"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_payment_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div style="border-bottom:3px solid #2e7d32;padding-bottom:10px;margin-bottom:16px;">
                            <h2 style="color:#2e7d32;margin:0;">PAYMENT RECEIPT</h2>
                            <p style="margin:4px 0 0;font-size:13px;">
                                Date: <strong><t t-esc="doc.date"/></strong>
                                &amp;nbsp;|&amp;nbsp;
                                Collector: <strong><t t-esc="doc.collector_id.name or ''"/></strong>
                            </p>
                        </div>
                        <table style="width:100%;border-collapse:collapse;font-size:13px;">
                            <thead>
                                <tr style="background:#2e7d32;color:white;">
                                    <th style="padding:8px;text-align:left;">Dealer</th>
                                    <th style="padding:8px;text-align:right;">Outstanding (Rs)</th>
                                    <th style="padding:8px;text-align:right;">Collected (Rs)</th>
                                    <th style="padding:8px;text-align:right;">Balance After (Rs)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.line_ids" t-as="line">
                                    <t t-if="line.collected_amount &gt; 0">
                                        <tr style="border-bottom:1px solid #eee;">
                                            <td style="padding:7px 8px;"><t t-esc="line.partner_id.name"/></td>
                                            <td style="padding:7px 8px;text-align:right;"><t t-esc="'%.2f' % line.outstanding"/></td>
                                            <td style="padding:7px 8px;text-align:right;font-weight:bold;color:#2e7d32;"><t t-esc="'%.2f' % line.collected_amount"/></td>
                                            <td style="padding:7px 8px;text-align:right;"><t t-esc="'%.2f' % line.balance_after"/></td>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background:#e8f5e9;font-weight:bold;">
                                    <td colspan="2" style="padding:8px;text-align:right;">Total Collected</td>
                                    <td style="padding:8px;text-align:right;color:#2e7d32;">
                                        Rs <t t-esc="'%.2f' % doc.total_collected"/>
                                    </td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                        <div style="margin-top:50px;display:flex;justify-content:space-between;">
                            <div style="border-top:1px solid #333;width:180px;padding-top:4px;font-size:11px;">Collector Signature</div>
                            <div style="border-top:1px solid #333;width:180px;padding-top:4px;font-size:11px;">Received By</div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
