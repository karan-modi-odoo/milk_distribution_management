<odoo>

    <record id="action_report_bill" model="ir.actions.report">
        <field name="name">Milk Bill</field>
        <field name="model">milk.dispatch.sheet</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">milk_distribution_management.report_bill</field>
        <field name="binding_model_id" ref="model_milk_dispatch_sheet"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_bill">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-foreach="doc.line_ids" t-as="line">
                    <t t-if="line.total_amount &gt; 0">
                        <t t-call="web.external_layout">
                            <div class="page">
                                <div style="border-bottom:3px solid #1a73e8;padding-bottom:10px;margin-bottom:16px;">
                                    <h2 style="color:#1a73e8;margin:0;">MILK BILL</h2>
                                    <span style="font-size:13px;">
                                        Ref: <strong><t t-esc="doc.name"/></strong>
                                        &amp;nbsp;|&amp;nbsp;
                                        Date: <t t-esc="doc.date"/>
                                        &amp;nbsp;|&amp;nbsp;
                                        Route:
                                        <t t-if="doc.route == 'rashmi_am'">Rashmi AM</t>
                                        <t t-elif="doc.route == 'giriraj_am'">Giriraj AM</t>
                                        <t t-elif="doc.route == 'pm'">PM</t>
                                    </span>
                                </div>
                                <div style="background:#f4f8ff;padding:10px;border-radius:4px;margin-bottom:16px;">
                                    <strong>Dealer: <t t-esc="line.partner_id.name"/></strong>
                                    <t t-if="line.partner_id.mobile">
                                        &amp;nbsp;|&amp;nbsp;
                                        <t t-esc="line.partner_id.mobile"/>
                                    </t>
                                </div>
                                <table style="width:100%;border-collapse:collapse;font-size:13px;">
                                    <thead>
                                        <tr style="background:#1a73e8;color:white;">
                                            <th style="padding:8px;text-align:left;">Product</th>
                                            <th style="padding:8px;text-align:center;">Qty/Crates</th>
                                            <th style="padding:8px;text-align:right;">Rate (Rs)</th>
                                            <th style="padding:8px;text-align:right;">Amount (Rs)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="line.product_line_ids" t-as="pl">
                                            <t t-if="pl.qty &gt; 0">
                                                <tr style="border-bottom:1px solid #eee;">
                                                    <td style="padding:7px 8px;"><t t-esc="pl.product_id.name"/></td>
                                                    <td style="padding:7px 8px;text-align:center;"><t t-esc="pl.qty"/></td>
                                                    <td style="padding:7px 8px;text-align:right;"><t t-esc="pl.rate"/></td>
                                                    <td style="padding:7px 8px;text-align:right;"><t t-esc="'%.2f' % pl.amount"/></td>
                                                </tr>
                                            </t>
                                        </t>
                                    </tbody>
                                    <tfoot>
                                        <tr style="background:#e8f0fe;font-weight:bold;">
                                            <td colspan="3" style="padding:8px;text-align:right;">Total</td>
                                            <td style="padding:8px;text-align:right;color:#1a73e8;">
                                                Rs <t t-esc="'%.2f' % line.total_amount"/>
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                                <p style="margin-top:24px;font-size:11px;color:#888;text-align:center;">
                                    Thank you for your business. Please make payment promptly.
                                </p>
                            </div>
                        </t>
                    </t>
                </t>
            </t>
        </t>
    </template>

</odoo>
