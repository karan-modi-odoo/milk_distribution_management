<odoo>

    <record id="action_report_driver_sheet" model="ir.actions.report">
        <field name="name">Driver Sheet</field>
        <field name="model">milk.dispatch.sheet</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">milk_distribution_management.report_driver</field>
        <field name="binding_model_id" ref="model_milk_dispatch_sheet"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_driver">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div style="border-bottom:3px solid #2e7d32;padding-bottom:10px;margin-bottom:16px;">
                            <h2 style="color:#2e7d32;margin:0;">DRIVER DELIVERY SHEET</h2>
                            <span style="font-size:13px;">
                                Ref: <strong><t t-esc="doc.name"/></strong>
                                &amp;nbsp;|&amp;nbsp;
                                Date: <t t-esc="doc.date"/>
                                &amp;nbsp;|&amp;nbsp;
                                Driver: <t t-esc="doc.driver_id.name or ''"/>
                                &amp;nbsp;|&amp;nbsp;
                                Route:
                                <t t-if="doc.route == 'rashmi_am'">Rashmi AM</t>
                                <t t-elif="doc.route == 'giriraj_am'">Giriraj AM</t>
                                <t t-elif="doc.route == 'pm'">PM</t>
                            </span>
                        </div>
                        <t t-foreach="doc.line_ids" t-as="line">
                            <t t-if="line.total_amount &gt; 0">
                                <div style="margin-bottom:16px;page-break-inside:avoid;">
                                    <div style="background:#e8f5e9;border-left:5px solid #2e7d32;padding:6px 12px;margin-bottom:4px;">
                                        <strong><t t-esc="line_index + 1"/>. <t t-esc="line.partner_id.name"/></strong>
                                    </div>
                                    <table style="width:100%;border-collapse:collapse;font-size:12px;">
                                        <thead>
                                            <tr style="background:#2e7d32;color:white;">
                                                <th style="padding:5px 8px;text-align:left;">Product</th>
                                                <th style="padding:5px 8px;text-align:center;">Qty/Crates</th>
                                                <th style="padding:5px 8px;text-align:right;">Amount (Rs)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="line.product_line_ids" t-as="pl">
                                                <t t-if="pl.qty &gt; 0">
                                                    <tr style="border-bottom:1px solid #eee;">
                                                        <td style="padding:5px 8px;"><t t-esc="pl.product_id.name"/></td>
                                                        <td style="padding:5px 8px;text-align:center;font-weight:bold;"><t t-esc="pl.qty"/></td>
                                                        <td style="padding:5px 8px;text-align:right;"><t t-esc="'%.2f' % pl.amount"/></td>
                                                    </tr>
                                                </t>
                                            </t>
                                        </tbody>
                                        <tfoot>
                                            <tr style="background:#e8f5e9;font-weight:bold;">
                                                <td colspan="2" style="padding:5px 8px;text-align:right;">Shop Total</td>
                                                <td style="padding:5px 8px;text-align:right;">Rs <t t-esc="'%.2f' % line.total_amount"/></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </t>
                        </t>
                        <div style="border-top:3px solid #2e7d32;padding-top:10px;text-align:right;margin-top:16px;">
                            <strong style="font-size:15px;color:#2e7d32;">
                                Grand Total: Rs <t t-esc="'%.2f' % sum(doc.line_ids.mapped('total_amount'))"/>
                            </strong>
                        </div>
                        <div style="margin-top:50px;display:flex;justify-content:space-between;">
                            <div style="border-top:1px solid #333;width:180px;padding-top:4px;font-size:11px;">Driver Signature</div>
                            <div style="border-top:1px solid #333;width:180px;padding-top:4px;font-size:11px;">Authorized Signature</div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
