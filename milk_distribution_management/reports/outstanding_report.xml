<odoo>

    <record id="action_report_outstanding" model="ir.actions.report">
        <field name="name">Outstanding Report</field>
        <field name="model">milk.outstanding.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">milk_distribution_management.report_outstanding</field>
    </record>

    <template id="report_outstanding">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div style="border-bottom:3px solid #1a73e8;padding-bottom:10px;margin-bottom:16px;">
                            <h2 style="color:#1a73e8;margin:0;">OUTSTANDING REPORT</h2>
                            <span style="font-size:13px;">
                                <t t-esc="company.name"/>
                            </span>
                        </div>
                        <table style="width:100%;border-collapse:collapse;font-size:13px;">
                            <thead>
                                <tr style="background:#1a73e8;color:white;">
                                    <th style="padding:8px;text-align:left;">No.</th>
                                    <th style="padding:8px;text-align:left;">Dealer</th>
                                    <th style="padding:8px;text-align:left;">Mobile</th>
                                    <th style="padding:8px;text-align:center;">Last Bill Date</th>
                                    <th style="padding:8px;text-align:right;">Outstanding (Rs)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.line_ids" t-as="line">
                                    <tr style="border-bottom:1px solid #eee;">
                                        <td style="padding:7px 8px;"><t t-esc="line_index + 1"/></td>
                                        <td style="padding:7px 8px;"><t t-esc="line.partner_id.name"/></td>
                                        <td style="padding:7px 8px;"><t t-esc="line.partner_id.mobile or ''"/></td>
                                        <td style="padding:7px 8px;text-align:center;"><t t-esc="line.last_date"/></td>
                                        <td style="padding:7px 8px;text-align:right;font-weight:bold;color:#d32f2f;">
                                            <t t-esc="'%.2f' % line.outstanding"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background:#e8f0fe;font-weight:bold;">
                                    <td colspan="4" style="padding:8px;text-align:right;">Total Outstanding</td>
                                    <td style="padding:8px;text-align:right;color:#1a73e8;">
                                        Rs <t t-esc="'%.2f' % doc.total_outstanding"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
