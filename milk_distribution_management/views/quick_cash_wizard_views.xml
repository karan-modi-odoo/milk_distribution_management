<odoo>

    <!-- ── Bulk Cash Collection Wizard — Form View ───────────────────────── -->

    <record id="view_quick_cash_wizard_form" model="ir.ui.view">
        <field name="name">milk.quick.cash.wizard.form</field>
        <field name="model">milk.quick.cash.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Cash Collection">
                <group>
                    <group>
                        <field name="date"/>
                        <field name="collector_id"
                               domain="[('milk_is_collector', '=', True)]"/>
                    </group>
                    <group>
                        <field name="total_amount"
                               string="Total to Collect (Rs)"
                               readonly="1"/>
                    </group>
                </group>

                <field name="line_ids">
                    <list editable="bottom"
                          decoration-muted="collected_amount == 0"
                          decoration-success="collected_amount > 0">
                        <field name="partner_id"
                               string="Dealer"
                               readonly="1"/>
                        <field name="outstanding"
                               string="Outstanding (Rs)"
                               readonly="1"/>
                        <field name="collected_amount"
                               string="Collected (Rs)"
                               optional="show"/>
                        <field name="payment_mode"
                               string="Mode"
                               widget="badge"
                               decoration-success="payment_mode == 'upi'"
                               decoration-info="payment_mode == 'cash'"
                               decoration-warning="payment_mode == 'cheque'"
                               optional="show"/>
                        <field name="balance_after"
                               string="Balance After (Rs)"
                               readonly="1"
                               optional="show"/>
                    </list>
                </field>

                <footer>
                    <button name="action_collect"
                            type="object"
                            string="Save &amp; Confirm Collection"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ── Window Action ─────────────────────────────────────────────────── -->

    <record id="action_quick_cash_wizard" model="ir.actions.act_window">
        <field name="name">Bulk Cash Collection</field>
        <field name="res_model">milk.quick.cash.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
