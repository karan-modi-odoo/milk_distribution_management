<odoo>

    <record id="driver_performance_form" model="ir.ui.view">
        <field name="name">milk.driver.performance.form</field>
        <field name="model">milk.driver.performance</field>
        <field name="arch" type="xml">
            <form string="Driver Performance">
                <sheet>
                    <group>
                        <group>
                            <field name="date_from" string="From Date"/>
                            <field name="date_to" string="To Date"/>
                        </group>
                    </group>
                    <group>
                        <button name="action_generate" type="object"
                                string="Generate" class="btn-primary"/>
                        <button name="action_print" type="object"
                                string="Print PDF" class="btn-secondary"
                                invisible="not line_ids"/>
                    </group>
                    <field name="line_ids" readonly="1">
                        <list>
                            <field name="driver_id" string="Driver"/>
                            <field name="total_sheets" string="Sheets" sum="Total"/>
                            <field name="total_dealers" string="Dealers Covered" sum="Total"/>
                            <field name="total_amount" string="Total Amount (Rs)" sum="Total"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="driver_performance_action" model="ir.actions.act_window">
        <field name="name">Driver Performance</field>
        <field name="res_model">milk.driver.performance</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

</odoo>
