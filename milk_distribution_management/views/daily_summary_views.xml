<odoo>

    <record id="daily_summary_list" model="ir.ui.view">
        <field name="name">milk.daily.summary.list</field>
        <field name="model">milk.daily.summary</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="total_rashmi" string="Rashmi (Rs)"/>
                <field name="total_giriraj" string="Giriraj (Rs)"/>
                <field name="total_pm" string="PM (Rs)"/>
                <field name="total_today" string="Total Today (Rs)"/>
                <field name="total_cash" string="Cash (Rs)"/>
                <field name="total_closing" string="Closing (Rs)"/>
            </list>
        </field>
    </record>

    <record id="daily_summary_form" model="ir.ui.view">
        <field name="name">milk.daily.summary.form</field>
        <field name="model">milk.daily.summary</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                        </group>
                        <group>
                            <button name="action_generate" type="object"
                                    string="Generate / Refresh" class="btn-primary"/>
                        </group>
                    </group>
                    <group string="Day Totals">
                        <group>
                            <field name="total_opening" string="Total Opening (Rs)" readonly="1"/>
                            <field name="total_rashmi" string="Rashmi AM (Rs)" readonly="1"/>
                            <field name="total_giriraj" string="Giriraj AM (Rs)" readonly="1"/>
                            <field name="total_pm" string="PM (Rs)" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_today" string="Total Today (Rs)" readonly="1"/>
                            <field name="total_cash" string="Cash Collected (Rs)" readonly="1"/>
                            <field name="total_closing" string="Total Outstanding (Rs)" readonly="1"/>
                        </group>
                    </group>
                    <field name="line_ids" readonly="1">
                        <list>
                            <field name="partner_id" string="Dealer"/>
                            <field name="opening_balance" string="Opening" sum="Total"/>
                            <field name="rashmi_amount" string="Rashmi AM" sum="Total"/>
                            <field name="giriraj_amount" string="Giriraj AM" sum="Total"/>
                            <field name="pm_amount" string="PM" sum="Total"/>
                            <field name="total_today" string="Total Today" sum="Total"/>
                            <field name="cash_received" string="Cash" sum="Total"/>
                            <field name="closing_balance" string="Closing" sum="Total"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="daily_summary_action" model="ir.actions.act_window">
        <field name="name">Daily Summary</field>
        <field name="res_model">milk.daily.summary</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
