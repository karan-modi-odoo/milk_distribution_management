<odoo>

    <record id="dealer_rate_list" model="ir.ui.view">
        <field name="name">milk.dealer.rate.list</field>
        <field name="model">milk.dealer.rate</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="dealer_id" string="Dealer"/>
                <field name="product_id" string="Product"/>
                <field name="rate" string="Rate (Rs)"/>
            </list>
        </field>
    </record>

    <record id="dealer_rate_form" model="ir.ui.view">
        <field name="name">milk.dealer.rate.form</field>
        <field name="model">milk.dealer.rate</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="dealer_id"/>
                        <field name="product_id"/>
                        <field name="rate" string="Rate (Rs)"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="dealer_rate_action" model="ir.actions.act_window">
        <field name="name">Dealer Rates</field>
        <field name="res_model">milk.dealer.rate</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
