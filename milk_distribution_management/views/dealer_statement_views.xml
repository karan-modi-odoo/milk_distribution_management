<odoo>

    <record id="dealer_statement_form" model="ir.ui.view">
        <field name="name">milk.dealer.statement.form</field>
        <field name="model">milk.dealer.statement</field>
        <field name="arch" type="xml">
            <form string="Dealer Statement">
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id" string="Dealer"/>
                            <field name="date_from" string="From Date"/>
                            <field name="date_to" string="To Date"/>
                        </group>
                        <group>
                            <field name="total_billed" string="Total Billed (Rs)" readonly="1"/>
                            <field name="total_paid" string="Total Paid (Rs)" readonly="1"/>
                            <field name="closing_balance" string="Closing Balance (Rs)" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <button name="action_generate" type="object"
                                string="Generate" class="btn-primary"/>
                        <button name="action_print" type="object"
                                string="Print PDF" class="btn-secondary"
                                invisible="not line_ids"/>
                    </group>
                    <field name="line_ids" readonly="1">
                        <list>
                            <field name="date"/>
                            <field name="opening_balance" string="Opening (Rs)"/>
                            <field name="today_bill" string="Bill (Rs)" sum="Total Billed"/>
                            <field name="received_amount" string="Cash (Rs)" sum="Total Paid"/>
                            <field name="closing_balance" string="Closing (Rs)"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="dealer_statement_action" model="ir.actions.act_window">
        <field name="name">Dealer Statement</field>
        <field name="res_model">milk.dealer.statement</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

</odoo>
