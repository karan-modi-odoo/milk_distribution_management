<odoo>

    <record id="outstanding_report_form" model="ir.ui.view">
        <field name="name">milk.outstanding.report.form</field>
        <field name="model">milk.outstanding.report</field>
        <field name="arch" type="xml">
            <form string="Outstanding Report">
                <sheet>
                    <group>
                        <group>
                            <field name="total_outstanding" string="Total Outstanding (Rs)" readonly="1"/>
                        </group>
                        <group>
                            <button name="action_generate" type="object"
                                    string="Generate" class="btn-primary"/>
                            <button name="action_print" type="object"
                                    string="Print PDF" class="btn-secondary"
                                    invisible="not line_ids"/>
                        </group>
                    </group>
                    <field name="line_ids" readonly="1">
                        <list>
                            <field name="partner_id" string="Dealer"/>
                            <field name="last_date" string="Last Bill Date"/>
                            <field name="outstanding" string="Outstanding (Rs)" sum="Total"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="outstanding_report_action" model="ir.actions.act_window">
        <field name="name">Outstanding Report</field>
        <field name="res_model">milk.outstanding.report</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

</odoo>
